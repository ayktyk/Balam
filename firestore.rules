rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Yardımcı fonksiyonlar
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getFamilyId() {
      return getUserData().familyId;
    }

    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Aileler
    match /families/{familyId} {
      allow read: if isAuthenticated() && (
        exists(/databases/$(database)/documents/families/{familyId}/members/$(request.auth.uid)) ||
        getFamilyId() == familyId
      );
      allow write: if isAuthenticated() && exists(/databases/$(database)/documents/families/{familyId}/members/$(request.auth.uid));
      
      // Aile üyeleri alt koleksiyonu
      match /members/{memberId} {
        allow read: if isAuthenticated() && (getFamilyId() == familyId || isOwner(memberId));
        allow write: if isAuthenticated() && isOwner(memberId);
      }
    }

    // Anılar (Entries)
    match /entries/{entryId} {
      // Okuma izni: Aile üyesiysen oku
      allow read: if isAuthenticated() && (
        resource == null || resource.data.familyId == getFamilyId()
      );
      
      // Yazma izni: Aile üyesiysen ve kendi familyId'ni yazıyorsan
      allow create: if isAuthenticated() && request.resource.data.familyId == getFamilyId();
      
      // Güncelleme/Silme izni: Kendi anınsa ve hala aynı aileye aitse
      allow update, delete: if isAuthenticated() && 
                             resource.data.authorId == request.auth.uid &&
                             resource.data.familyId == getFamilyId();
    }
  }
}
